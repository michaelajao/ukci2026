# ---------------------------------------------------------------------------
# Project-specific
# ---------------------------------------------------------------------------

# Raw data — too large, downloaded from public sources. Ignore raw archives
# anywhere under data/raw/ (including the data/raw/ root itself, not just the
# nhs/ and supporting/ subfolders) so manually-dropped downloads don't show up
# as untracked noise for collaborators.
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.zip
data/raw/*.csv
data/raw/nhs/*.xlsx
data/raw/nhs/*.zip
data/raw/nhs/*.csv
data/raw/supporting/*.xlsx
data/raw/supporting/*.xls
data/raw/supporting/*.csv
data/raw/supporting/*.zip

# Keep manifests and gitkeeps under version control
!data/raw/nhs/MANIFEST.txt
!data/raw/nhs/.gitkeep
!data/raw/supporting/MANIFEST.txt
!data/raw/supporting/.gitkeep

# Processed data — regeneratable from raw
data/processed/*.csv
data/processed/*.parquet
data/processed/*.feather
!data/processed/.gitkeep
!data/processed/README.md

# Results and figures are COMMITTED as the shared source of truth so the
# co-author gets paper-facing tables/figures without re-running the heavy
# pipeline. Do not ignore results/ or figures/ contents. (Bulky raw NHS data
# is still ignored above; large model checkpoints are ignored via *.pt/*.pth.)

# LaTeX build artefacts (when paper drafting begins)
docs/paper/build/
docs/paper/out/
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc

# Local secrets / API keys
.env
.env.local
*.key
secrets/

# Solver licences
gurobi.lic
.claude/scheduled_tasks.lock
