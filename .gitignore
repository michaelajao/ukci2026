.venv/
venv/
env/
ENV/

# PyTorch / model checkpoints
*.pt
*.pth
*.ckpt
*.onnx

# Jupyter
.ipynb_checkpoints
*.ipynb_checkpoints

# Hydra outputs
outputs/
multirun/

